{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roota",
  "version": "0.2.0",
  "identifier": "com.roota.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Roota",
        "width": 400,
        "height": 300,
        "minWidth": 340,
        "minHeight": 260,
        "resizable": true,
        "center": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "fullscreen": false,
        "dragDropEnabled": false
      },
      {
        "label": "overlay",
        "title": "Roota Overlay",
        "fullscreen": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "shadow": false,
        "url": "index.html?overlay=1",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Roota — local AI assistant for seniors.",
    "longDescription": "Roota is a fully offline accessibility-first desktop companion that turns natural-language commands into one-step-at-a-time visual guidance. It never automates input — it only guides.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
