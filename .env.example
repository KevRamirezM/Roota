# ── Roota environment configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# The .env file is gitignored and must never be committed.

# LLM
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512

# Speech-to-Text (faster-whisper)
WHISPER_MODEL_SIZE=small
WHISPER_LANGUAGE=es
STT_DEVICE=cpu

# Text-to-Speech
TTS_RATE=150
TTS_VOLUME=1.0

# UI
UI_FONT_SIZE=22
UI_LANGUAGE=es

# Overlay
OVERLAY_OPACITY=0.85
OVERLAY_FPS=30

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
